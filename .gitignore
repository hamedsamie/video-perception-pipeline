# =====================================================
# Generated Outputs
# =====================================================

# Intermediate pipeline artifacts
outputs/frames/
outputs/detections/
outputs/tracks/

# Generated videos (if large)
outputs/videos/

# Ignore all evaluation outputs by default
outputs/evaluation/*
!outputs/evaluation/.gitkeep
!outputs/evaluation/*.csv
!outputs/evaluation/*.json

# Ignore all visualizations by default
outputs/visualizations/*
!outputs/visualizations/.gitkeep
!outputs/visualizations/**/*.jpg
!outputs/visualizations/**/*.png
!outputs/visualizations/**/*.mp4

# Ignore exports by default
outputs/*
!outputs/predictions.jsonl

# Allow visualizations and evaluation folders
!outputs/visualizations/
!outputs/evaluation/

# Downloaded Videos (must never be committed)
data/videos/**
*.mp4
*.avi
*.mov
*.mkv
*.webm

# YOLO weights
yolov8n.pt
*.pt